  "properties": {
    "beneficiario_fino": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "estado_extraccion": {
          "$ref": "#/$defs/estado_extraccion"
        },
        "tipo_beneficiario_fino": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "autonomo",
            "microempresa",
            "pequena_empresa",
            "mediana_empresa",
            "gran_empresa",
            "otro",
            "no_determinado",
            null
          ],
          "description": "Filtro derivado atómico respecto de tiposBeneficiarios BDNS. Clasifica al beneficiario formal que puede solicitar, no a los miembros internos de una agrupación. Usar autonomo para persona física con actividad económica. Usar microempresa/pequena_empresa/mediana_empresa/gran_empresa solo cuando el beneficiario formal sea una empresa individual o una categoría empresarial directa restringida por la Recomendación 2003/361/CE. Usar otro para agrupaciones, UTE, consorcios, agrupaciones sin personalidad jurídica, comunidades de bienes, entidades públicas, universidades, entidades sin ánimo de lucro u otras figuras no encajables en tamaño empresarial UE. Explicar en texto_beneficiario_fino. Usar no_determinado si no puede clasificarse."
        },
        "texto_beneficiario_fino": {
          "type": [
            "string",
            "null"
          ],
          "description": "Texto normalizado para ficha y auditoría. Debe explicar el beneficiario real cuando el enum no baste: consorcio, UTE, agrupación, entidades públicas concretas, empresas tractoras, etc."
        },
        "formas_juridicas_excluidas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "antiguedad_minima_meses": {
          "type": [
            "integer",
            "null"
          ]
        },
        "empleo_minimo_trabajadores": {
          "type": [
            "integer",
            "null"
          ]
        },
        "admite_consorcio": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "True si la fuente permite expresamente consorcios/cooperación formal; false si los excluye; null si no se menciona. Para UTE o agrupaciones no denominadas consorcio, reflejar en texto_beneficiario_fino y descripcion_para_ficha."
        },
        "condiciones_consorcio": {
          "type": [
            "string",
            "null"
          ]
        },
        "minimo_miembros_consorcio": {
          "type": [
            "integer",
            "null"
          ]
        },
        "maximo_miembros_consorcio": {
          "type": [
            "integer",
            "null"
          ]
        },
        "requiere_pyme_en_consorcio": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "porcentaje_maximo_por_entidad_o_grupo": {
          "type": [
            "number",
            "null"
          ]
        },
        "descripcion_para_ficha": {
          "type": [
            "string",
            "null"
          ],
          "description": "Narrativa para ficha ejecutiva. Interpretar y sintetizar, no copiar literalmente."
        },
        "evidencias": {
          "$ref": "#/$defs/evidencias"
        }
      },
      "required": [
        "estado_extraccion",
        "tipo_beneficiario_fino",
        "texto_beneficiario_fino",
        "formas_juridicas_excluidas",
        "antiguedad_minima_meses",
        "empleo_minimo_trabajadores",
        "admite_consorcio",
        "condiciones_consorcio",
        "minimo_miembros_consorcio",
        "maximo_miembros_consorcio",
        "requiere_pyme_en_consorcio",
        "porcentaje_maximo_por_entidad_o_grupo",
        "descripcion_para_ficha",
        "evidencias"
      ],
      "description": "Bloque de granularización del beneficiario respecto de BDNS. El filtro tipo_beneficiario_fino es atómico y clasifica al beneficiario formal; los requisitos internos de agrupaciones/consorcios se explican en campos textuales y condiciones_consorcio."
    },
