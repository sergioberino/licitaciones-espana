{
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "estado_extraccion": {
      "type": "string",
      "enum": [
        "explicito",
        "inferido",
        "no_encontrado",
        "no_aplica",
        "contradictorio",
        "remite_a_otro_documento"
      ],
      "description": "Estado operativo de extracción. Usar explicito si el dato aparece en la fuente; inferido solo para síntesis razonable; no_encontrado si debería existir pero no aparece; no_aplica si la categoría no procede; contradictorio si hay conflicto entre fuentes; remite_a_otro_documento si la fuente deriva a otra norma/anexo/convocatoria."
    },
    "evidencia": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "documento": {
          "type": "string",
          "enum": [
            "bases_reguladoras",
            "texto_convocatoria",
            "anexo",
            "extracto_bdns",
            "convocatoria_detalle_bdns",
            "diario_oficial",
            "otra_norma",
            "no_identificado"
          ]
        },
        "localizador": {
          "type": [
            "string",
            "null"
          ],
          "description": "Artículo, base, apartado, anexo, página o epígrafe si está disponible."
        },
        "cita_breve": {
          "type": [
            "string",
            "null"
          ],
          "description": "Cita corta o paráfrasis muy pegada a fuente. No pegar párrafos largos; objetivo máximo orientativo: 280 caracteres."
        }
      },
      "required": [
        "documento",
        "localizador",
        "cita_breve"
      ]
    },
    "evidencias": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidencia"
      },
      "description": "Evidencias breves del bloque. Preferencia operativa: 1-3 evidencias, cita breve y localizador si existe. Vacío si no hay fuente localizable."
    },
