# =============================================================================
# ETL — Variables de entorno (ejemplo)
# =============================================================================
# Copiar a .env y rellenar: cp .env.example .env
# En contenedor el runtime puede cargar vía env_file. En host, export o source .env.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=licitaciones
DB_USER=postgres
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Schema de trabajo (requerido para init-db)
# Nombre del schema donde el ETL crea objetos para ingesta (p. ej. raw, staging).
# -----------------------------------------------------------------------------
DB_SCHEMA=raw
# Schema dim (referencia; puede venir del root .env vía distribute-env.sh)
DIM_SCHEMA=dim
BORME_SCHEMA=borme

# -----------------------------------------------------------------------------
# Lotes (ingest)
# -----------------------------------------------------------------------------
INGEST_BATCH_SIZE=8192

# -----------------------------------------------------------------------------
# Rutas (opcional)
# -----------------------------------------------------------------------------
LICITACIONES_TMP_DIR=/app/tmp
# LICITACIONES_SCHEMAS_DIR=./schemas

# -----------------------------------------------------------------------------
# DIR3 (init-db ingesta Listado Unidades AGE) -> No necesario por ahora
# -----------------------------------------------------------------------------
# DIR3_XLSX_URL=

# -----------------------------------------------------------------------------
# NLP — Batch B (Track B WP2.1)
# En el monorepo licitia-ingestion estas vars vienen del .env raíz vía
# scripts/distribute-env.sh (whitelist ETL_KEYS). En desarrollo standalone
# del submódulo, rellenar aquí directamente.
# -----------------------------------------------------------------------------
NLP_LLM_PROVIDER=openai
NLP_LLM_MODEL=gpt-5.4-nano
OPENAI_API_KEY=
NLP_LLM_TIMEOUT_S=180
